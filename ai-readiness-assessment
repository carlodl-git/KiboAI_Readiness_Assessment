              <div style={{width:4,height:38,borderRadius:2,background:dim.accent,flexShrink:0}}/>
              <div style={{flex:1}}>
                <h2 style={{fontFamily:"'Playfair Display',serif",fontSize:21,fontWeight:700,color:"#f5f0e8",margin:"0 0 3px"}}>{dim.title}</h2>
