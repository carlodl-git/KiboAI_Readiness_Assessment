const fmtDate = d => new Date(d).toLocaleDateString("en-GB",{day:"numeric",month:"short",year:"numeric"});

function RadarChart({scores,size=260}){
  const cx=size/2,cy=size/2,r=size*0.34;
  const n=DIMENSIONS.length;
  const angle=i=>(Math.PI*2*i/n)-Math.PI/2;
  const pt=(i,frac)=>({x:cx+r*frac*Math.cos(angle(i)),y:cy+r*frac*Math.sin(angle(i))});
  const gridPts=lv=>DIMENSIONS.map((_,i)=>pt(i,lv/5));
  const scorePts=DIMENSIONS.map((d,i)=>pt(i,(scores[d.id]||0)/5));
  return(
    <svg viewBox={`0 0 ${size} ${size}`} style={{width:"100%",maxWidth:size}}>
      {[1,2,3,4,5].map(lv=>(
        <polygon key={lv} points={gridPts(lv).map(p=>`${p.x},${p.y}`).join(" ")} fill="none" stroke="rgba(255,255,255,0.07)" strokeWidth="1"/>
      ))}
      {DIMENSIONS.map((_,i)=>{const p=pt(i,1);return<line key={i} x1={cx} y1={cy} x2={p.x} y2={p.y} stroke="rgba(255,255,255,0.07)" strokeWidth="1"/>;} )}
      <polygon points={scorePts.map(p=>`${p.x},${p.y}`).join(" ")} fill="rgba(201,162,39,0.12)" stroke="#c9a227" strokeWidth="1.5"/>
      {scorePts.map((p,i)=><circle key={i} cx={p.x} cy={p.y} r="4" fill={DIMENSIONS[i].accent} stroke="#0a0f1a" strokeWidth="1.5"/>)}
      {DIMENSIONS.map((d,i)=>{
        const a=angle(i),lx=cx+(r+24)*Math.cos(a),ly=cy+(r+24)*Math.sin(a);
        return<text key={i} x={lx} y={ly} textAnchor="middle" dominantBaseline="middle" style={{fontSize:9,fontWeight:700,fill:"rgba(255,255,255,0.6)",fontFamily:"DM Sans,sans-serif",letterSpacing:0.3}}>{d.short}</text>;
      })}
    </svg>
  );
}

