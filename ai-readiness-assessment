            <input type="date" value={workshopDate} onChange={e=>setWorkshopDate(e.target.value)} style={{...field,colorScheme:"dark"}}
              onFocus={e=>e.target.style.borderColor="rgba(201,162,39,0.5)"}
              onBlur={e=>e.target.style.borderColor="rgba(255,255,255,0.12)"}/>
          </div>
        </div>
        <div style={{display:"flex",gap:10}}>
          <button onClick={onClose} style={{flex:1,padding:"12px",background:"transparent",border:"1px solid rgba(255,255,255,0.12)",borderRadius:9,color:"rgba(255,255,255,0.55)",cursor:"pointer",fontFamily:"'DM Sans',sans-serif",fontSize:14,fontWeight:600}}>Cancel</button>
          <button onClick={handleCreate} disabled={!companyName.trim()} style={{flex:2,padding:"12px",background:companyName.trim()?"linear-gradient(135deg,#c9a227,#f0d060)":"rgba(255,255,255,0.04)",border:"none",borderRadius:9,color:companyName.trim()?"#070c14":"rgba(255,255,255,0.2)",cursor:companyName.trim()?"pointer":"not-allowed",fontFamily:"'DM Sans',sans-serif",fontSize:14,fontWeight:700,transition:"all 0.15s"}}>
